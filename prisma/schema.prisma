generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model Provider {
  id              String        @id @default(cuid())
  name            String        @unique
  type            String
  isActive        Boolean       @default(true)
  scraperScript   String?
  lastSyncAt      DateTime?
  lastSyncSuccess Boolean?
  mainAccounts    MainAccount[]
}

model MainAccount {
  id          String       @id @default(cuid())
  label       String
  providerId  String
  mfUrlId     String?      @unique
  sortOrder   Int          @default(0)
  provider    Provider     @relation(fields: [providerId], references: [id])
  subAccounts SubAccount[]

  @@index([providerId])
}

model SubAccount {
  id               String           @id @default(cuid())
  mainAccountId    String
  currentName      String
  assetType        AssetType        @default(CASH)
  balance          Int
  sortOrder        Int              @default(0)
  isHidden         Boolean          @default(false)
  histories        BalanceHistory[]
  cryptos          CryptoAsset[]
  holdings         Holding[]
  holdingHistories HoldingHistory[]
  pointDetail      PointDetail?
  mainAccount      MainAccount      @relation(fields: [mainAccountId], references: [id], onDelete: Cascade)
  transactions     Transaction[]

  @@unique([mainAccountId, currentName])
  @@index([mainAccountId])
  @@index([assetType])
  @@index([isHidden])
}

model BalanceHistory {
  id           String     @id @default(cuid())
  subAccountId String
  date         DateTime
  balance      Int
  subAccount   SubAccount @relation(fields: [subAccountId], references: [id], onDelete: Cascade)

  @@unique([subAccountId, date])
  @@index([subAccountId])
  @@index([date])
}

model Holding {
  id             String     @id @default(cuid())
  subAccountId   String
  name           String
  quantity       Float
  avgCostBasis   Int
  unitPrice      Int
  valuation      Int
  dayBeforeRatio Int
  gainLoss       Int
  gainLossRate   Float
  updatedAt      DateTime   @updatedAt
  subAccount     SubAccount @relation(fields: [subAccountId], references: [id], onDelete: Cascade)

  @@unique([subAccountId, name])
  @@index([subAccountId])
}

model HoldingHistory {
  id           String     @id @default(cuid())
  subAccountId String
  name         String
  quantity     Float
  avgCostBasis Int
  unitPrice    Int
  valuation    Int
  gainLoss     Int
  gainLossRate Float
  date         DateTime
  createdAt    DateTime   @default(now())
  subAccount   SubAccount @relation(fields: [subAccountId], references: [id], onDelete: Cascade)

  @@unique([subAccountId, name, date])
  @@index([subAccountId, name])
  @@index([date])
}

model CryptoAsset {
  id             String     @id @default(cuid())
  subAccountId   String
  symbol         String
  name           String
  quantity       Float
  price          Float
  valuation      Int
  dayBeforeRatio Int?
  updatedAt      DateTime   @updatedAt
  subAccount     SubAccount @relation(fields: [subAccountId], references: [id], onDelete: Cascade)

  @@index([subAccountId])
}

model PointDetail {
  id             String     @id @default(cuid())
  subAccountId   String     @unique
  points         Float
  rate           Float      @default(1.0)
  expirationDate DateTime?
  subAccount     SubAccount @relation(fields: [subAccountId], references: [id], onDelete: Cascade)
}

model MainCategory {
  id            String            @id @default(cuid())
  name          String
  type          CategoryType      @default(EXPENSE)
  sortOrder     Int               @default(0)
  subCategories SubCategoryItem[]

  @@unique([name, type])
}

model SubCategoryItem {
  id             String         @id @default(cuid())
  name           String
  mainCategoryId String
  sortOrder      Int            @default(0)
  rules          CategoryRule[]
  mainCategory   MainCategory   @relation(fields: [mainCategoryId], references: [id])
  transactions   Transaction[]

  @@unique([mainCategoryId, name])
  @@index([mainCategoryId])
}

model Transaction {
  id            String           @id
  subAccountId  String
  date          DateTime         @db.Date
  amount        Int
  desc          String
  subCategoryId String?
  isTransfer    Boolean          @default(false)
  transferId    String?
  linkedTransId String?
  subAccount    SubAccount       @relation(fields: [subAccountId], references: [id], onDelete: Cascade)
  subCategory   SubCategoryItem? @relation(fields: [subCategoryId], references: [id])

  @@index([date])
  @@index([subCategoryId])
  @@index([subAccountId])
  @@index([subAccountId, date])
  @@index([isTransfer])
  @@index([transferId])
  @@index([linkedTransId])
  @@index([amount])
}

model CategoryRule {
  id            String          @id @default(cuid())
  keyword       String
  subCategoryId String
  priority      Int             @default(0)
  subCategory   SubCategoryItem @relation(fields: [subCategoryId], references: [id])

  @@unique([keyword, subCategoryId])
  @@index([subCategoryId])
}

enum AssetType {
  CASH
  INVESTMENT
  CRYPTO
  POINT
  LIABILITY
}

enum CategoryType {
  INCOME
  EXPENSE
}
