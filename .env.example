# Database
DATABASE_URL="postgresql://my-assets_user:my-assets_password@localhost:5432/my-assets"

# App
APP_PORT=3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"
TZ="Asia/Tokyo"
BASIC_AUTH_USER="admin"
BASIC_AUTH_PASSWORD="changeme"

# PostgreSQL (for docker-compose / production deploy)
POSTGRES_USER="my-assets_user"
POSTGRES_PASSWORD="my-assets_password"
POSTGRES_DB="my-assets"
DB_PORT="5432"

# Docker Images and Deployment
APP_IMAGE="ghcr.io/babcs2035/my-assets"
IMAGE_TAG="latest"

# 1Password Integration
# Option 1: Using service account token (recommended for CI/CD)
OP_SERVICE_ACCOUNT_TOKEN=""
OP_VAULT=""

# Note on Production Deployment:
# When deploying with docker-compose.production.yml, the container requires access to 1Password CLI.
# The host system must have 1Password CLI installed at /usr/bin/op.
# The docker-compose configuration will automatically mount:
#   - /usr/bin/op:/usr/bin/op:ro (read-only 1Password executable)
#   - /usr/lib:/usr/lib:ro (read-only shared libraries required by op)
# 
# On the deploy host, ensure:
#   1. 1Password CLI is installed: https://1password.com/downloads/command-line/
#   2. You are authenticated: op signin <account>
#   3. The socket_dir is available for vault access

