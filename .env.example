# Database
DATABASE_URL="postgresql://my-assets_user:CHANGE_ME_PASSWORD@localhost:5432/my-assets"

# App
APP_PORT=3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"
TZ="Asia/Tokyo"
BASIC_AUTH_USER="admin"
BASIC_AUTH_PASSWORD="changeme"

# PostgreSQL (for docker-compose / production deploy)
POSTGRES_USER="my-assets_user"
POSTGRES_PASSWORD="CHANGE_ME_PASSWORD"
POSTGRES_DB="my-assets"
DB_PORT="5432"

# Docker Images and Deployment
APP_IMAGE="ghcr.io/babcs2035/my-assets"
IMAGE_TAG="latest"

# 1Password Integration (deploy-time only)
# Credentials are extracted on the deploy host via `op item get` during deployment
# and stored in data/runtime/op-secrets.json, then bind-mounted into the container.
# See deploy workflow for details.
OP_SERVICE_ACCOUNT_TOKEN=""
OP_VAULT=""
OP_MF_ITEM_ID="MF_Main"
